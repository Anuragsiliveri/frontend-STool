# GitHub Personal Access Token (classic or fine-grained, read-only access is sufficient)
# Required to avoid GitHub API rate limits (60 req/hour unauthenticated → 5,000 req/hour authenticated)
# Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# GitLab Personal Access Token with read_api scope
# Required to access private GitLab repositories or avoid rate limits
# Generate one at: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=
